# ============================================================
# EMart Environment Variables — TEMPLATE
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it contains secrets.
# .env is in .gitignore; .env.example is committed.
# ============================================================

# Node environment: development | test | production
NODE_ENV=development

# ------------------------------------------------------------
# Database (filled in during Step 6)
# ------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/emart

# ------------------------------------------------------------
# API (filled in during Step 8)
# ------------------------------------------------------------
# API_PORT=4000
# JWT_ACCESS_SECRET=replace-with-random-64-char-string
# JWT_REFRESH_SECRET=replace-with-another-random-64-char-string

# ------------------------------------------------------------
# Web (filled in during Step 13)
# ------------------------------------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:4000

# ------------------------------------------------------------
# LLM APIs (filled in during Phase 2 — Step 25 onward)
# ------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# GOOGLE_GEMINI_API_KEY=...

# ------------------------------------------------------------
# AWS (filled in during Phase 1 deploy — Step 20 onward)
# ------------------------------------------------------------
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...